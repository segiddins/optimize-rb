# frozen_string_literal: true
require "rake/testtask"

Rake::TestTask.new(:test) do |t|
  t.libs << "lib" << "test"
  t.pattern = "test/**/*_test.rb"
  t.warning = false
end

task default: :test

RAW_BENCH_SECTION_RE = /## Raw benchmark output\n\n```\n.*?```/m
BENCH_LINE_RE        = /^  (plain|optimized):.*i\/s.*$/
HEADER_RATIO_RE      = /^Pipeline\.default: \*\*[\d.]+x\*\* vs unoptimized\.$/

def mask_nondeterministic(md)
  md
    .sub(RAW_BENCH_SECTION_RE,
         "## Raw benchmark output\n\n```\n<benchmark output>\n```")
    .gsub(BENCH_LINE_RE, '  \1: <ips>')
    .sub(HEADER_RATIO_RE, "Pipeline.default: **<ratio>x** vs unoptimized.")
end

namespace :demo do
  desc "Regenerate docs/demo_artifacts/claude_*.md by calling `claude -p` for each claude_*.claude_cases.yml sidecar. Non-deterministic; review the diff before committing. Requires ANTHROPIC_API_KEY or a prior `claude setup-token`. Pass STEM=<name> to regenerate just one."
  task :regenerate_claude do
    unless ENV["ANTHROPIC_API_KEY"] || ENV["CLAUDE_CODE_SSO_TOKEN"]
      warn "Warning: neither ANTHROPIC_API_KEY nor CLAUDE_CODE_SSO_TOKEN is set. " \
           "If `claude setup-token` hasn't been run in this environment, the call will fail."
    end
    warn "This will overwrite docs/demo_artifacts/claude_*.md. " \
         "Claude's output is non-deterministic — review the diff before committing."
    examples_dir = File.expand_path("examples", __dir__)
    bin          = File.expand_path("bin/demo-claude", __dir__)
    stems =
      if ENV["STEM"]
        [ENV["STEM"]]
      else
        Dir[File.join(examples_dir, "claude_*.claude_cases.yml")]
          .map { |p| File.basename(p, ".claude_cases.yml") }
      end
    abort "no claude_*.claude_cases.yml sidecars found" if stems.empty?
    stems.each { |s| sh bin, s }
  end

  desc "Regenerate demo artifacts and diff against the committed versions"
  task :verify do
    require "tmpdir"
    require "fileutils"
    $LOAD_PATH.unshift(File.expand_path("lib", __dir__))
    require "ruby_opt/demo/runner"
    examples_dir  = File.expand_path("examples", __dir__)
    committed_dir = File.expand_path("../docs/demo_artifacts", __dir__)
    sidecars = Dir[File.join(examples_dir, "*.walkthrough.yml")]
    abort "no sidecars found" if sidecars.empty?

    Dir.mktmpdir do |tmp|
      mismatches = []
      sidecars.each do |sc|
        stem = File.basename(sc, ".walkthrough.yml")
        regenerated = RubyOpt::Demo::Runner.run(sidecar_path: sc, output_dir: tmp)
        committed = File.join(committed_dir, "#{stem}.md")
        unless File.exist?(committed)
          mismatches << "missing committed artifact: #{committed}"
          next
        end
        if mask_nondeterministic(File.read(regenerated)) !=
           mask_nondeterministic(File.read(committed))
          mismatches << stem
        end
      end
      # Claude gag artifacts are non-deterministic (regenerated opt-in via
      # `rake demo:regenerate_claude`). Verify only that each committed
      # markdown exists and is non-empty. One per claude_*.claude_cases.yml
      # sidecar in optimizer/examples.
      claude_sidecars = Dir[File.join(examples_dir, "claude_*.claude_cases.yml")]
      claude_sidecars.each do |sc|
        stem = File.basename(sc, ".claude_cases.yml")
        artifact = File.join(committed_dir, "#{stem}.md")
        unless File.exist?(artifact) && File.size(artifact).positive?
          mismatches << "#{stem}.md missing or empty"
        end
      end

      if mismatches.empty?
        puts "demo:verify OK (#{sidecars.size} fixtures + #{claude_sidecars.size} claude)"
      else
        abort "demo:verify FAILED for: #{mismatches.join(', ')}. " \
              "Re-run `bin/demo --all` and commit the regenerated artifacts."
      end
    end
  end
end
